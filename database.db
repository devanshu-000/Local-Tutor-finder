SELECT t.name, t.location, t.mode, s.subject_name
FROM Tutors t
JOIN Tutor_Subjects ts ON t.tutor_id = ts.tutor_id
JOIN Subjects s ON ts.subject_id = s.subject_id
WHERE s.subject_name = 'Math'
AND t.location = 'Dehradun'
AND t.mode IN ('offline', 'both')
AND t.status = 'approved';

